{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",

    "dialog:allow-open",

    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:read-all",

    "shell:allow-open",

    {
      "identifier": "fs:scope",
      "allow": [
        "D:/Projects/doughts/doughts/**"
      ]
    }
  ]
}